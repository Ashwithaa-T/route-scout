# ──────────────────────────────────────────────
#  RouteScout — Environment Variables Template
#  Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Google Gemini API key (leave blank to run in MOCK_LLM mode)
GOOGLE_API_KEY=

# Set to "true" to use mock LLM responses (no API calls)
MOCK_LLM=true

# Port on which the local MCP weather server listens
MCP_SERVER_PORT=5001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Application host/port (used when running directly)
APP_HOST=0.0.0.0
APP_PORT=8000
